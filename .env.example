# Frontend/backend connection.
# Set this to your public PocketBase URL in DockPanel, Dokploy, Vercel, etc.
VITE_POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_URL=http://127.0.0.1:8090
PORT=4173

# Required for local production server reminder testing.
# Use your local PocketBase superuser account.
POCKETBASE_SUPERUSER_EMAIL=
POCKETBASE_SUPERUSER_PASSWORD=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
POCKETBASE_TEMP_PASSWORD=ChangeMe123!
SMOKE_EMAIL=
SMOKE_PASSWORD=

# Brevo SMTP settings for report reminder emails.
# SMTP_USER is usually your Brevo SMTP login.
# SMTP_PASS must be a Brevo SMTP key, not your Brevo account password.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_STARTTLS=1
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=PSO-Aurora
PSA_LOGO_URL=https://pso-aurora.com/PSA.png
