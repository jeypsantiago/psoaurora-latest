{
  "name": "psa-provincial-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/compress-dist-assets.mjs",
    "check": "npm run lint && npm run typecheck && npm run build && npm run smoke:build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start:prod": "node --env-file=.env scripts/production-server.mjs",
    "ops:runner": "node scripts/ops-runner.mjs",
    "pocketbase:bootstrap": "node scripts/pocketbase-bootstrap.mjs",
    "health:public": "node scripts/health-check.mjs",
    "reports:reminders": "node scripts/send-report-reminders.mjs",
    "smoke:build": "node scripts/build-smoke.mjs",
    "smoke:connectivity": "node scripts/connectivity-ui-smoke.mjs",
    "smoke:landing-settings": "node scripts/landing-settings-smoke.mjs",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.4",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.13.5",
    "docxtemplater": "^3.68.2",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "0.344.0",
    "pdf-lib": "^1.17.1",
    "pizzip": "^3.2.0",
    "pocketbase": "^0.26.8",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.8.0",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.2.0"
  }
}
